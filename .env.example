# 启动时默认用哪个 provider：anthropic | openai | deepseek
# （运行时还能用 /model 命令随时切换）
PROVIDER=anthropic

# --- Anthropic（Claude 原生协议）---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- DeepSeek（OpenAI 兼容协议，单列成一等 provider）---
# 模型：deepseek-chat / deepseek-reasoner（旧名，2026-07 前可用）
#       deepseek-v4-flash / deepseek-v4-pro（新名，1M 上下文）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 其他 OpenAI 兼容接口（官方 OpenAI / Kimi / 通义 / OpenRouter…）---
# 官方 OpenAI 留空 OPENAI_BASE_URL 即可
# Kimi:      OPENAI_BASE_URL=https://api.moonshot.cn/v1 OPENAI_MODEL=moonshot-v1-8k
# 通义:      OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 OPENAI_MODEL=qwen-plus
# OpenRouter:OPENAI_BASE_URL=https://openrouter.ai/api/v1 OPENAI_MODEL=...
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# 仪表盘端口（绑定 127.0.0.1）
DASHBOARD_PORT=4100
